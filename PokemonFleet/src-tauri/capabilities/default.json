{
  "$schema": "https://schema.tauri.app/config/2/permissions/2",
  "identifier": "default",
  "description": "Default permissions for PokemonFleet",
  "windows": ["main"],
  "remote": {
    "urls": ["http://**", "https://**"]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "opener:default",
    "opener:allow-open-url"
  ]
}
